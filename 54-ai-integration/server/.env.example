# ============================================================
# .env.example — Variables de entorno necesarias para el servidor
# ============================================================
# Copia este archivo como .env y reemplaza el valor con tu API key real.
# NUNCA subas el archivo .env a un repositorio de control de versiones.
#
# Seguridad: La API key vive SOLO en el servidor. El navegador NUNCA
# la ve. Si alguien inspecciona la red desde el navegador, solo verá
# peticiones a localhost:3000, nunca a api.openai.com.

OPENAI_API_KEY=your-api-key-here
