{
  "name": "mod37-microfrontends",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npm run start:mfe",
    "build": "ng build",
    "build:shell": "ng build shell-app",
    "build:remote": "ng build remote-app",
    "start:shell": "ng serve shell-app --port 4200",
    "start:remote": "ng serve remote-app --port 4201",
    "start:mfe": "concurrently \"npm run start:shell\" \"npm run start:remote\""
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-architects/module-federation": "^19.0.0",
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.0",
    "concurrently": "^9.0.0",
    "typescript": "~6.0.2",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.0.0"
  }
}
