{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": { "packageManager": "npm" },
  "newProjectRoot": "projects",
  "projects": {
    "shell-app": {
      "projectType": "application",
      "root": "projects/shell-app",
      "sourceRoot": "projects/shell-app/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-architects/module-federation:browser",
          "options": {
            "main": "projects/shell-app/src/main.ts",
            "tsConfig": "projects/shell-app/tsconfig.app.json",
            "assets": [{ "glob": "**/*", "input": "projects/shell-app/public" }],
            "styles": ["projects/shell-app/src/styles.css"],
            "extraWebpackConfig": "projects/shell-app/webpack.mf.config.js",
            "publicPath": "auto"
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial", "maximumWarning": "500kB", "maximumError": "1MB" },
                { "type": "anyComponentStyle", "maximumWarning": "4kB", "maximumError": "8kB" }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-architects/module-federation:dev-server",
          "configurations": {
            "production": { "buildTarget": "shell-app:build:production" },
            "development": { "buildTarget": "shell-app:build:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    },
    "remote-app": {
      "projectType": "application",
      "root": "projects/remote-app",
      "sourceRoot": "projects/remote-app/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-architects/module-federation:browser",
          "options": {
            "main": "projects/remote-app/src/main.ts",
            "tsConfig": "projects/remote-app/tsconfig.app.json",
            "assets": [{ "glob": "**/*", "input": "projects/remote-app/public" }],
            "styles": ["projects/remote-app/src/styles.css"],
            "extraWebpackConfig": "projects/remote-app/webpack.mf.config.js",
            "publicPath": "auto"
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial", "maximumWarning": "500kB", "maximumError": "1MB" },
                { "type": "anyComponentStyle", "maximumWarning": "4kB", "maximumError": "8kB" }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-architects/module-federation:dev-server",
          "configurations": {
            "production": { "buildTarget": "remote-app:build:production" },
            "development": { "buildTarget": "remote-app:build:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
